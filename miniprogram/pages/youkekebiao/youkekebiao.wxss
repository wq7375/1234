/* pages/youkekebiao/youkekebiao.wxss */

.container {
  padding: 24rpx;
  background: #f7f7fa;
  min-height: 100vh;
}

.top-tip {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #a78ee4 0%, #7a3fc3 100%);
  border-radius: 16rpx;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(122, 63, 195, 0.2);
}

.public-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.public-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 课程类型切换 - 占满一整行 */
.tab-bar {
  display: flex;
  margin-bottom: 20rpx;
  width: 100%;
}

.tab {
  flex: 1 1 100px;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tab:first-child {
  border-radius: 16rpx 0 0 16rpx;
}

.tab:last-child {
  border-radius: 0 16rpx 16rpx 0;
}

.tab-active {
  background: #a78ee4;
  color: #fff;
}

.tab-inactive {
  background: #ede4f7;
  color: #7a3fc3;
}

/* 周切换 - 占满一整行 */
.week-bar {
  display: flex;
  margin-bottom: 20rpx;
  width: 100%;
}

.week-tab {
  flex: 1 1 100px;
  padding: 20rpx 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.week-tab:first-child {
  border-radius: 12rpx 0 0 12rpx;
}

.week-tab:last-child {
  border-radius: 0 12rpx 12rpx 0;
}

.week-tab-active {
  background: #a78ee4;
  color: #fff;
}

.week-tab-inactive {
  background: #ede4f7;
  color: #7a3fc3;
}

.table-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.table-title {
  font-size: 32rpx;
  color: #7a3fc3;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.course-row {
  margin-bottom: 30rpx;
}

.course-date {
  font-size: 30rpx;
  color: #a78ee4;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.date-text {
  margin-right: 16rpx;
}

.week-day {
  background: #a78ee4;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.lesson-card {
  background: #f7f7fa;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s;
}

.lesson-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.lesson-info {
  flex: 1;
}

.lesson-time {
  color: #1aad19;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.lesson-content {
  color: #333;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.lesson-teacher {
  color: #666;
  font-size: 24rpx;
}

.disabled-btn {
  background: #eee;
  color: #bbb;
  border-radius: 10rpx;
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border: none;
  margin-left: 20rpx;
}

.no-lesson-tip {
  background: #f7f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  color: #888;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 60rpx 20rpx;
}

.empty-tip text {
  display: block;
  margin-top: 20rpx;
}

.bottom-tip {
  text-align: center;
  font-size: 24rpx;
  color: #888;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

/* 响应式设计 */
@media (max-width: 600rpx) {
  .lesson-card {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .disabled-btn {
    margin-top: 20rpx;
    margin-left: 0;
    align-self: flex-end;
  }
}